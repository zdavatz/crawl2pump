/target
Cargo.lock.*
.chrome-profile/
.flaresolverr/
.flaresolverr-src/
*.tmp.html
# Scratch space for throwaway one-off binaries (e.g. ad-hoc report generators).
# Keep them out of the published crate; real bins are explicitly whitelisted.
/src/bin/*
!/src/bin/pumpfoil_report.rs
!/src/bin/meta_post.rs
# Generated PDF/HTML catalogs.
/pumpfoil-sets.pdf
/pumpfoil-sets.html

# SQLite database files (the schema is in src/db.rs; data is local)
sqlite/*.db
sqlite/*.db-shm
sqlite/*.db-wal

# Local-only files
/resume
/.meta.env
